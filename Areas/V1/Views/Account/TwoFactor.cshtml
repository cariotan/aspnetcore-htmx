@model TwoFactorModel

@{
	ViewData["Title"] = "2FA";
}

<title>@ViewData["Title"]</title>

<div
	x-data=
	'
		{
			twoFactor_buttonSpinner:
			{
				isLoading: false,
			},
		}
	'
	class='h-screen'
>
	<div class='flex flex-col justify-center min-h-full px-6 py-12 lg:px-8'>
		<div class='sm:mx-auto sm:w-full sm:max-w-sm'>
			<img
				alt='Company'
				src='https://tailwindui.com/plus-assets/img/logos/mark.svg?color=indigo&shade=600' 
				class='mx-auto w-auto h-10'
			/>
			<h2 class='mt-10 text-center text-2xl/9 text-gray-900 font-bold tracking-tight'>
				Sign in to your account
			</h2>
		</div>
		<div class='mt-10 sm:mx-auto sm:w-full sm:max-w-sm'>
			<form
				x-on:submit='twoFactor_buttonSpinner.isLoading = true'
				hx-post='@Url.Action()'
				hx-target='#wrapper'
				hx-swap='outerHTML'
				hx-select='#wrapper'
				class='space-y-6'
			>
				<div>
					<label asp-for='@Model.Code' class='block text-gray-900 text-sm/6 font-medium'>
						Code
					</label>
					<div class='mt-2'>
						<input
							asp-for='@Model.Code'
							value='@Model?.Code'
							class='block rounded-md outline outline-1 outline-gray-300 -outline-offset-1 w-full bg-white px-3 py-1.5 text-base text-gray-900 placeholder:text-gray-400 focus:outline focus:outline-2 focus:outline-indigo-600 focus:-outline-offset-2 sm:text-sm/6'
						/>
						@Html.ValidationMessageFor(x => x.Code)
					</div>
				</div>
				<div class='flex items-start'>
					<div class='flex items-center h-6'>
						<input
							type='checkbox'
							asp-for='RememberClient'
							class='rounded border-gray-300 w-4 h-4 text-indigo-600 focus:ring-indigo-600'
						/>
					</div>
					<div class='ml-3 text-sm/6'>
						<label asp-for='RememberClient' class='text-gray-900 font-medium'>
							Remember this device
						</label>
						<p class='text-gray-500'>
							Skip 2FA on this browser next time
						</p>
					</div>
				</div>
				@Html.ValidationMessageFor(x => x.RememberClient)
				<div>
					<button
						type='submit'
						class='rounded-md flex justify-center w-full bg-indigo-600 px-3 py-1.5 text-sm/6 text-white font-semibold shadow-sm focus-visible:outline focus-visible:outline-2 focus-visible:outline-indigo-600 focus-visible:outline-offset-2 hover:bg-indigo-500'
					>
						<partial name='_ButtonSpinner' model='"twoFactor_buttonSpinner"' />
						<span x-opacity='!twoFactor_buttonSpinner.isLoading'>
							Sign in
						</span>
					</button>
					@Html.ValidationMessage("Error")
				</div>
				<input
					type='hidden'
					name='returnUrl'
					value='@ViewData["ReturnUrl"]'
				/>
			</form>
			<p class='mt-10 text-center text-gray-500 text-sm/6'>
				Not a member?
				<a
					hx-get='@Url.Action("Register")'
					hx-push-url='true'
					hx-target='#wrapper'
					hx-swap='outerHTML'
					hx-select='#wrapper'
					class='text-indigo-600 font-semibold cursor-pointer hover:text-indigo-500'
				>
					Register here
				</a>
			</p>
		</div>
	</div>
</div>